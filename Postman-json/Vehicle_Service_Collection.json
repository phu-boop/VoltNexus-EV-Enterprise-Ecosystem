{
    "info": {
        "name": "Vehicle Service API Automation Testing",
        "description": "Postman Collection for VehicleCatalogController & ImageController applying 13 automation testing techniques.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Models (CRUD)",
            "item": [
                {
                    "name": "1. GET Models Paginated",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 1. HTTP Status Code Testing",
                                    "pm.test(\"Status code is 200 OK\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// 11. Query Parameter Testing",
                                    "// 5. Nested Object Validation",
                                    "pm.test(\"Response contains pagination metadata\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.result).to.have.property('content');",
                                    "    pm.expect(jsonData.result).to.have.property('totalElements');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/vehicle-catalog/models?page=0&size=10",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "vehicle-catalog",
                                "models"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "0"
                                },
                                {
                                    "key": "size",
                                    "value": "10"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "2. POST Create Model With Variants",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status code is 201 Created\", function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "// 13. Environment Variable Usage",
                                    "var jsonData = pm.response.json();",
                                    "if(pm.response.code === 201 && jsonData.result) {",
                                    "    pm.environment.set(\"test_model_id\", jsonData.result.modelId);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"modelName\": \"AutoTest Model {{$timestamp}}\",\n    \"brand\": \"VoltNexus\",\n    \"vehicleType\": \"SUV\",\n    \"batteryCapacity\": 100,\n    \"rangePerCharge\": 500,\n    \"description\": \"Automation Test Model\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/vehicle-catalog/models",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "vehicle-catalog",
                                "models"
                            ]
                        }
                    }
                },
                {
                    "name": "3. PUT Update Model",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status code is 200 OK\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "X-User-Email",
                                "value": "{{test_email}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"modelName\": \"AutoTest Model Updated\",\n    \"brand\": \"VoltNexus\",\n    \"vehicleType\": \"SUV\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/vehicle-catalog/models/{{test_model_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "vehicle-catalog",
                                "models",
                                "{{test_model_id}}"
                            ]
                        }
                    }
                },
                {
                    "name": "4. GET Model Details",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status code is 200 OK\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// 7. Expected Data Verification",
                                    "pm.test(\"Verify ID is correct\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.result.modelId.toString()).to.eql(pm.environment.get(\"test_model_id\").toString());",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/vehicle-catalog/models/{{test_model_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "vehicle-catalog",
                                "models",
                                "{{test_model_id}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Variants & Comparisons",
            "item": [
                {
                    "name": "1. POST Create Variant",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status is 201 Created\", function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "var jsonData = pm.response.json();",
                                    "if(pm.response.code === 201 && jsonData.result) {",
                                    "    pm.environment.set(\"test_variant_id\", jsonData.result.variantId);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "X-User-Email",
                                "value": "{{test_email}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"versionName\": \"Long Range\",\n    \"year\": 2026,\n    \"color\": \"Red\",\n    \"specs\": \"Leather seats\",\n    \"basePrice\": 55000\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/vehicle-catalog/models/{{test_model_id}}/variants",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "vehicle-catalog",
                                "models",
                                "{{test_model_id}}",
                                "variants"
                            ]
                        }
                    }
                },
                {
                    "name": "2. POST Compare Variants",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 4. JSON Schema Validation",
                                    "pm.test(\"Comparison results should be an array\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.result).to.be.an('array');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "X-User-ProfileId",
                                "value": "{{dealer_id}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "[\n    {{test_variant_id}}\n]"
                        },
                        "url": {
                            "raw": "{{base_url}}/vehicle-catalog/compare",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "vehicle-catalog",
                                "compare"
                            ]
                        }
                    }
                }
            ]
        },
        {
