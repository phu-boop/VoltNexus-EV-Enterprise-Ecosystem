                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "X-User-Email",
                                "value": "{{test_email}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"featureId\": {{test_feature_id}}\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/vehicle-catalog/variants/{{test_variant_id}}/features",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "vehicle-catalog",
                                "variants",
                                "{{test_variant_id}}",
                                "features"
                            ]
                        }
                    }
                }
            ]
        },
