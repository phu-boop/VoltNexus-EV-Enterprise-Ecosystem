{
    "info": {
        "name": "Inventory Service API Automation Testing",
        "description": "Postman Collection for Inventory Service applying 13 automation testing techniques.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Inventory Status",
            "item": [
                {
                    "name": "1. GET All Inventory (Central)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 1. HTTP Status Code Testing",
                                    "pm.test(\"Status is 200\", function(){ pm.response.to.have.status(200); });",
                                    "// 4. JSON Schema Validation",
                                    "pm.test(\"Verify pageable response\", function() {",
                                    "    var data = pm.response.json().result;",
                                    "    pm.expect(data).to.have.property('content');",
                                    "    pm.expect(data.content).to.be.an('array');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/inventory?page=0&size=10",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "inventory"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "0"
                                },
                                {
                                    "key": "size",
                                    "value": "10"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "2. GET My Stock (Dealer)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 8. Authentication Testing",
                                    "pm.test(\"Status is 200\", function(){ pm.response.to.have.status(200); });"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "X-User-ProfileId",
                                "value": "{{dealer_id}}"
                            },
                            {
                                "key": "X-User-Email",
                                "value": "{{test_email}}"
                            },
                            {
                                "key": "X-User-Role",
                                "value": "DEALER_MANAGER"
                            },
                            {
                                "key": "X-User-Id",
                                "value": "{{user_id}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/inventory/my-stock",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "inventory",
                                "my-stock"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Transactions",
            "item": [
                {
                    "name": "1. POST Execute Transaction (Receive)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 9. CRUD API Testing (Create transaction)",
                                    "pm.test(\"Status is 200\", function(){ pm.response.to.have.status(200); });"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "X-User-Email",
                                "value": "{{test_email}}"
                            },
                            {
                                "key": "X-User-Role",
                                "value": "EVM_STAFF"
                            },
                            {
                                "key": "X-User-ProfileId",
                                "value": "{{user_id}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"variantId\": 1,\n    \"transactionType\": \"RECEIVE\",\n    \"quantity\": 10,\n    \"note\": \"Initial stock inward\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/inventory/transactions",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "inventory",
                                "transactions"
                            ]
                        }
                    }
                },
                {
                    "name": "2. GET Transaction History",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test(\"Status is 200\", function(){ pm.response.to.have.status(200); });"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/inventory/transactions?page=0&size=10",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "inventory",
                                "transactions"
                            ],
                            "query": [
                                {
                                    "key": "page",
                                    "value": "0"
                                },
                                {
                                    "key": "size",
                                    "value": "10"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "3. Stock Alerts",
            "item": [
                {
                    "name": "1. GET Active Alerts",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 5. Nested Object Validation",
                                    "pm.test(\"Status is 200\", function(){ pm.response.to.have.status(200); });",
                                    "pm.test(\"Verify alerts list\", function(){ pm.expect(pm.response.json().result).to.be.an('array'); });"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/inventory/alerts",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "inventory",
                                "alerts"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}