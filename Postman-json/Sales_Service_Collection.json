    "item": [
        {
            "name": "1. Promotions Management",
            "item": [
                {
                    "name": "1. GET Active Promotions",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 1. HTTP Status Code Testing",
                                    "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                                    "",
                                    "// 3. Data Type Checking",
                                    "// 4. JSON Schema Validation",
                                    "pm.test(\"Verify response is array\", function () { pm.expect(pm.response.json()).to.be.an('array'); });",
                                    "",
                                    "// 13. Environment Variable Usage",
                                    "var jsonData = pm.response.json();",
                                    "if(jsonData.length > 0) { pm.environment.set(\"test_promotion_id\", jsonData[0].id); }"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/promotions/active",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "promotions",
                                "active"
                            ]
                        }
                    }
                },
                {
                    "name": "2. POST Create Promotion",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 9. CRUD API Testing (Create)",
                                    "pm.test(\"Status is 200\", function(){ pm.response.to.have.status(200); });",
                                    "var jsonData = pm.response.json();",
                                    "if(jsonData.id) { pm.environment.set(\"new_promotion_id\", jsonData.id); }"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Test Promotion {{$timestamp}}\",\n    \"description\": \"Discount for EV\",\n    \"discountValue\": 5000000,\n    \"discountType\": \"FIXED_AMOUNT\",\n    \"startDate\": \"2026-01-01\",\n    \"endDate\": \"2026-12-31\",\n    \"status\": \"DRAFT\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/promotions",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "promotions"
                            ]
                        }
                    }
                }
            ]
