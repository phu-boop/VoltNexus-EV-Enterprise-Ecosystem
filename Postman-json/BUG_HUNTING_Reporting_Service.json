      "name": "1. CRITICAL - Authentication Bypass",
      "item": [
        {
          "name": "BUG-01: Admin Backfill - NO AUTH REQUIRED",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// BUG: API Admin ma KHONG can token van truy cap duoc",
                  "// File: SecurityConfig.java:26 - anyRequest().permitAll()",
                  "// File: AdminBackfillController.java:48 - @PreAuthorize bi comment",
                  "",
                  "pm.test(\"[BUG-01] CRITICAL: Admin API accessible WITHOUT token\", function() {",
                  "    // Neu status KHONG PHAI 401/403 -> BUG NGHIEM TRONG!",
                  "    if (pm.response.code !== 401 && pm.response.code !== 403) {",
                  "        console.error('BUG NGHIEM TRONG: Admin API khong yeu cau xac thuc!');",
                  "        console.error('Status Code:', pm.response.code);",
                  "        console.error('Response:', pm.response.text());",
                  "        pm.expect.fail('CRITICAL BUG: Admin API phai tra ve 401/403 khi khong co token, nhung tra ve: ' + pm.response.code);",
                  "    } else {",
                  "        pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "        console.log('OK: API duoc bao ve dung cach');",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"[BUG-01] Phat hien: PreAuthorize bi tat\", function() {",
                  "    // Kiem tra xem co tra ve du lieu hay khong (khong nen co)",
                  "    const code = pm.response.code;",
                  "    if (code === 200 || code === 400) {",
                  "        pm.expect.fail('BUG: @PreAuthorize(hasRole(ADMIN)) dang bi comment/tat trong AdminBackfillController.java');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{url_reporting}}/api/v1/admin/backfill/dealers",
