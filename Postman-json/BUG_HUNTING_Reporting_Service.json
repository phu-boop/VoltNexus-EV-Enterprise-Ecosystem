      "name": "0. SETUP - Nhap Admin Token",
      "item": [
        {
          "name": "HUONG DAN: Set admin_token trong Variables",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// HUONG DAN SU DUNG:",
                  "// 1. Vao tab 'Variables' cua Collection nay",
                  "// 2. Tim bien 'admin_token'",
                  "// 3. Paste JWT token cua admin vao cot 'CURRENT VALUE'",
                  "// 4. Save lai",
                  "",
                  "pm.test(\"Kiem tra admin_token da duoc set\", function() {",
                  "    const token = pm.collectionVariables.get('admin_token');",
                  "    ",
                  "    if (!token || token === '' || token === 'PASTE_YOUR_ADMIN_TOKEN_HERE') {",
                  "        console.warn('========================================');",
                  "        console.warn('CHUA SET TOKEN!');",
                  "        console.warn('Vao tab Variables -> admin_token');",
                  "        console.warn('Paste JWT token vao CURRENT VALUE');",
                  "        console.warn('========================================');",
                  "        pm.expect.fail('Chua set admin_token! Xem huong dan trong Console.');",
                  "    } else {",
                  "        console.log('admin_token da duoc set!');",
                  "        console.log('Token length:', token.length);",
                  "        pm.expect(token.length).to.be.greaterThan(10);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{url_reporting}}/reports/inventory",
              "host": [
                "{{url_reporting}}"
              ],
              "path": [
                "reports",
                "inventory"
              ]
            },
            "description": "HUONG DAN SET TOKEN:\n\n1. Vao tab 'Variables' cua Collection\n2. Tim dong 'admin_token'\n3. Paste JWT token vao cot 'CURRENT VALUE'\n4. Save (Ctrl+S)\n\nSau do chay request nay de kiem tra token hop le."
          },
          "response": []
        }
      ]
