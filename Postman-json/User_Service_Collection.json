                {
                    "name": "2. GET Dealer Staffs with Query Param",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 11. Query Parameter Testing",
                                    "pm.test(\"Status code is 200 OK\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// 3. Data Type Checking",
                                    "pm.test(\"Result should be an array\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.result).to.be.an('array');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/users/dealer-staffs?dealerId={{dealer_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users",
                                "dealer-staffs"
                            ],
                            "query": [
                                {
                                    "key": "dealerId",
                                    "value": "{{dealer_id}}"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
