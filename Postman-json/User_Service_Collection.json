{
    "info": {
        "name": "User Service API Automation Testing",
        "description": "Postman Collection for UserController, ProfileController, and NotificationController applying 13 automation testing techniques.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. User Management (CRUD)",
            "item": [
                {
                    "name": "1. GET All Users",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 1. HTTP Status Code Testing",
                                    "pm.test(\"Status code is 200 OK\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// 4. JSON Schema Validation",
                                    "var schema = {",
                                    "    \"type\": \"object\",",
                                    "    \"required\": [\"code\", \"message\", \"result\"],",
                                    "    \"properties\": {",
                                    "        \"result\": { \"type\": \"array\" }",
                                    "    }",
                                    "};",
                                    "pm.test(\"Response matches schema layout\", function () {",
                                    "    pm.response.to.have.jsonSchema(schema);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/users",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users"
                            ]
                        }
                    }
                },
                {
                    "name": "2. POST Create EVM Staff (Create)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 9. CRUD API Testing (Create)",
                                    "pm.test(\"Status code is 201 Created\", function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "// 13. Environment Variable Usage",
                                    "var jsonData = pm.response.json();",
                                    "if(pm.response.code === 201 && jsonData.result && jsonData.result.id) {",
                                    "    pm.environment.set(\"test_staff_id\", jsonData.result.id);",
                                    "}",
                                    "",
                                    "// 5. Nested Object Validation",
                                    "pm.test(\"User ID exists in result\", function () {",
                                    "    pm.expect(jsonData.result).to.have.property('id');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"evmstaff_{{$timestamp}}@example.com\",\n    \"password\": \"Password123!@#\",\n    \"fullName\": \"Automation EVM Staff\",\n    \"phone\": \"0988000000\",\n    \"roles\": [\"EVM_STAFF\"]\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/users/register/evmStaff",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users",
                                "register",
                                "evmStaff"
                            ]
                        }
                    }
                },
                {
                    "name": "3. GET User by ID (Read)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 9. CRUD API Testing (Read)",
                                    "pm.test(\"Status code is 200 OK\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// 7. Expected Data Verification",
                                    "pm.test(\"Verify user ID matches assigned\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.result.id).to.eql(pm.environment.get(\"test_staff_id\"));",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/users/{{test_staff_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users",
                                "{{test_staff_id}}"
                            ]
                        }
                    }
                },
                {
                    "name": "4. PUT Update User (Update)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 9. CRUD API Testing (Update)",
                                    "pm.test(\"Status code is 200 OK\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// 2. Response Body Validation",
                                    "pm.test(\"Message indicates update success\", function () {",
                                    "    pm.expect(pm.response.text()).to.include(\"Update User Successfully\");",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"fullName\": \"Automation EVM Staff Updated\",\n    \"phone\": \"0988111111\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/users/{{test_staff_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users",
                                "{{test_staff_id}}"
                            ]
                        }
                    }
                },
                {
                    "name": "5. DELETE User (Delete)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 9. CRUD API Testing (Delete)",
                                    "pm.test(\"Status code is 200 OK\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// 6. Loop / Collection Testing Simulation",
                                    "pm.test(\"Cleanup logic simulation\", function () {",
                                    "    pm.environment.unset(\"test_staff_id\");",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/users/{{test_staff_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "users",
                                "{{test_staff_id}}"
                            ]
                        }
                    }
                }
            ]
        },
