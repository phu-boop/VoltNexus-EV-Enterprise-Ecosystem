{
    "info": {
        "name": "Dealer Service API Automation Testing",
        "description": "Postman Collection for DealerController and DealerContractController applying 13 automation testing techniques.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Dealers (CRUD)",
            "item": [
                {
                    "name": "1. GET All Dealers",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 1. HTTP Status Code Testing",
                                    "pm.test(\"Status code is 200 OK\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// 4. JSON Schema Validation",
                                    "// 5. Nested Object Validation",
                                    "pm.test(\"Result is an array of dealers\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.result).to.be.an('array');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/dealers",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "dealers"
                            ]
                        }
                    }
                },
                {
                    "name": "2. POST Create Dealer",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 9. CRUD API Testing (Create)",
                                    "pm.test(\"Status code is 201 Created\", function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "// 13. Environment Variable Usage",
                                    "var jsonData = pm.response.json();",
                                    "if(pm.response.code === 201 && jsonData.result) {",
                                    "    pm.environment.set(\"test_dealer_id\", jsonData.result.dealerId);",
                                    "    pm.environment.set(\"test_dealer_code\", jsonData.result.dealerCode);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{admin_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"dealerName\": \"AutoTest Dealer {{$timestamp}}\",\n    \"city\": \"Hanoi\",\n    \"address\": \"Test Address\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/dealers",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "dealers"
                            ]
                        }
                    }
                },
                {
                    "name": "3. GET Dealer By ID",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "// 9. CRUD API Testing (Read)",
                                    "pm.test(\"Status is 200\", function(){ pm.response.to.have.status(200); });",
                                    "",
                                    "// 7. Expected Data Verification",
                                    "pm.test(\"Dealer ID matches environment\", function() {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.result.dealerId).to.eql(pm.environment.get(\"test_dealer_id\"));",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/dealers/{{test_dealer_id}}",
                            "host": [
                                "{{base_url}}"
